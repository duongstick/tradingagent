# --- vnquant showcase configuration ---
# This showcase runs entirely on synthetic data and needs NO secrets to run.
# The variables below are placeholders illustrating what a production deployment
# would require. Copy to `.env` and fill in only if you wire up real integrations.

# Random seed for reproducible synthetic data
VNQUANT_SEED=42

# (Production only — NOT used by the showcase) data vendor / broker placeholders
# DATA_API_KEY=your_key_here
# BROKER_USERNAME=your_username
# BROKER_PASSWORD=your_password
# BROKER_ACCOUNT_NO=your_account
